{
  "manifest_version": 3,
  "name": "HH Booster",
  "version": "1.1",
  "description": "Автоматизация обновления резюме и ответов в чате",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "HH Booster: Статус системы"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.hh.ru/*",
    "https://chatik.hh.ru/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.hh.ru/*"],
      "js": ["parser-service.js", "about-editor-service.js", "content.js"],
      "all_frames": false,
      "css": [
        "styles.css"
      ]
    },
    {
      "matches": ["https://chatik.hh.ru/*"],
      "js": ["chat-service.js"],
      "all_frames": true,
      "css": [
        "styles.css"
      ]
    }
  ]
}